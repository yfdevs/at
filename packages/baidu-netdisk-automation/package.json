{
  "name": "@drama/baidu-netdisk-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./download-baidu-folder": {
      "types": "./src/download-baidu-folder.ts",
      "development": "./src/download-baidu-folder.ts",
      "default": "./dist/download-baidu-folder.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "check": "tsc --noEmit",
    "download:share": "node --experimental-strip-types src/download-baidu-folder.ts"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/ws": "^8.18.1",
    "typescript": "latest",
    "vite": "catalog:"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
