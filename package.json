{
  "name": "drama-post-auto",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "pnpm --filter @drama/wechat-video-automation build && pnpm --filter @drama/meituan-creation-automation build && vp dev",
    "build": "pnpm --filter @drama/wechat-video-automation build && pnpm --filter @drama/meituan-creation-automation build && pnpm wechat-video:install-browsers && tsc && vp build && electron-builder --config electron-builder.json5",
    "lint": "vp lint",
    "preview": "vp preview",
    "wechat-video:install-browsers": "node scripts/install-playwright-browsers.mjs",
    "wechat-video:check": "pnpm --filter @drama/wechat-video-automation check",
    "meituan-creation:check": "pnpm --filter @drama/meituan-creation-automation check",
    "meituan-creation:build": "pnpm --filter @drama/meituan-creation-automation build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@drama/meituan-creation-automation": "workspace:*",
    "@drama/wechat-video-automation": "workspace:*",
    "@fontsource-variable/geist": "^5.2.9",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-window-state": "^5.0.3",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "playwright": "latest",
    "playwright-core": "latest",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.0",
    "recharts": "3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "systeminformation": "^5.31.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.8.0"
}
